
<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h1 class="card-title mb-0"><%= @category.name.capitalize %></h1>
        <% if logged_in? && current_user.admin? %>
          <div class="btn-group">
            <%= link_to 'Edit', edit_category_path(@category), class: "btn btn-outline-primary btn-sm" %>
            <%= button_to 'Delete', category_path(@category), method: :delete,
                class: "btn btn-outline-danger btn-sm",
                confirm: "Are you sure? This will remove the category from all articles.",
                form: { style: "display: inline-block;" } %>
          </div>
        <% end %>
      </div>
      <div class="card-body">
        <% if @category.articles.any? %>
          <h5>Articles in this category (<%= @category.articles.count %>)</h5>
          <div class="list-group">
            <% @category.articles.each do |article| %>
              <div class="list-group-item d-flex justify-content-between align-items-start">
                <div class="ms-2 me-auto">
                  <div class="fw-bold">
                    <%= link_to article.title, article_path(article), class: "text-decoration-none" %>
                  </div>
                  <small class="text-muted">
                    by <%= article.user&.name || "Unknown" %> • 
                    <%= article.created_at.strftime("%B %d, %Y") %>
                  </small>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-4">
            <i class="bi bi-journal-text display-4 text-muted"></i>
            <h5 class="text-muted">No articles in this category yet</h5>
            <p class="text-muted">Articles with this category will appear here.</p>
          </div>
        <% end %>
      </div>
      <div class="card-footer">
        <%= link_to 'All Categories', categories_path, class: "btn btn-secondary" %>
        <%= link_to 'All Articles', articles_path, class: "btn btn-primary" %>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Category Info</h5>
      </div>
      <div class="card-body">
        <p><strong>Name:</strong> <%= @category.name.capitalize %></p>
        <p><strong>Articles:</strong> <%= pluralize(@category.articles.count, 'article') %></p>
        <p><strong>Created:</strong> <%= @category.created_at.strftime("%B %d, %Y") %></p>
      </div>
    </div>
  </div>
</div>